local function CloneCharacter(Thing,Player)
	local Char = Thing:Clone()
	pcall(function()
		Char.HumanoidRootPart.AuraAttachment:Destroy()
		for i,L in pairs(Char:GetDescendants()) do
			if not L:IsA("Part") and not L:IsA("BasePart") and not L:IsA("Decal") and not L:IsA("Pants") and not L:IsA("Shirt") and not L:IsA("Humanoid") then
				L:Destroy()
			end
		end
		Char.Humanoid.DisplayDistanceType = "None"
		Char.HumanoidRootPart.Anchored = true
		Char.HumanoidRootPart.CFrame = Thing.PrimaryPart.CFrame
		pcall(function()
			Char.HumanoidRootPart.ScouterEffect:Destroy()
		end)
	end)
	for i,v in pairs(Char:GetDescendants()) do
		if v:IsA("Part") or v:IsA("BasePart") then
			pcall(function()
				v.Anchored = true
				v.Transparency += 0.6
				for i,x in pairs(v:GetChildren()) do
					if x:IsA("Weld") or x:IsA("Motor6D") and x.Name ~= "Hair6D" then
						x:Destroy()
					end
				end
				for i,x in pairs(v:GetDescendants()) do
					if x:IsA("ParticleEmitter") then
						x:Destroy()
					end
				end
				pcall(function()
					if Thing:FindFirstChild(v.Name) then
						v.CFrame = Thing[v.Name].CFrame
					end
				end)
			end)
			v.CollisionGroup = "MiscBots"
			game:GetService("TweenService"):Create(v,TweenInfo.new(0.5),{Transparency=1}):Play()
		elseif v:IsA("Decal") then
			v.Transparency = 1
		end
	end
	Char.Parent = workspace.MouseIgnore
	RemoveItem(Char,0.5)
end
