				Vector3.new(13.5,13.5,13.5), -- First Ball Size
				Color3.fromRGB(4, 175, 236), -- Second Ball Color
				Vector3.new(13,13,13), -- Second Ball Color
				0.5, -- First Part Transparency
				0, -- Second Part Transparency
				Character.HumanoidRootPart.CFrame*CFrame.new(0,0,-5.987), -- first part cframe 
				Character.HumanoidRootPart.CFrame*CFrame.new(0,0,-5.987), -- second part cframe
				0.5, -- First Beam Transparency
				0, -- Second Beam Transparency
				Vector3.new(4, 11.077, 11.07), -- First Beam Size Lenght
				Vector3.new(3.5,10.577,10.57), -- Second Beam Size Lenght
				2, -- Beam Lenght
				3.5, -- Beam Duration 4.833
				0.1, -- Beam Daamge
				false, -- Can Explode
				Vector3.new(10,10,10), -- Beam Explosion Size (not neccesary if disabled)
				v.Parent, -- v.Parent (Player)
				true, -- can push
				0.8, -- PushSpeed (tweeninfo)
				35, -- PushDistance (CFrame)
				Move)
			local SPAT = os.clock()
			repeat
				game:GetService("RunService").Heartbeat:Wait()
			until os.clock() - SPAT >= 0.5 * Speed or Character.Humanoid.Health <= 0
			--Broke = true
			Finished = true	
			RemoveItem(Stun,1.25)
			RemoveItem(Inv2,1.25)
		end)
		if err then print(err) end
		CharAnim:Stop()
		if plr then	Character:FindFirstChild("IsSpecial").Value = false	end
		v.Parent.Humanoid.AutoRotate = true
		v.Parent.HumanoidRootPart.Anchored = false
		v.Parent.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
		spawn(function() Inv2:Destroy() end)
	end,
}
return module
