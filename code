local function Knockback(v,StartingPosition,Duration,Anim,Goal,WallStun,IFrames,AnimationID,TimePosition,AnimSpeed,DurationBasedOnTimePassed,UpwardsVelocity)
	local Start = os.clock()
	local Inv = nil
	if IFrames == true then
		local Invincibility2 = Instance.new("BoolValue")
		Invincibility2.Name = "Invincibility"
		Invincibility2.Parent = v.Parent
		RemoveItem(Invincibility2,Duration + 0.5)
		Inv = Invincibility2
	end
	local Stunned2 = false
	local Connection = v.Parent.ChildAdded:Connect(function(Child)
		if Child.Name == "Stun" then
			Stunned2 = true
		end
	end)
	spawn(function()
		v.Parent.HumanoidRootPart.CFrame = StartingPosition
		local Tween = game:GetService("TweenService"):Create(v.Parent.HumanoidRootPart,TweenInfo.new(workspace.SpeedUp.Value * Duration,Enum.EasingStyle.Linear),{CFrame=Goal})
		Tween:Play()
		v.Parent.Humanoid.AutoRotate = false
		v.Parent.HumanoidRootPart.Anchored = true
		local TimePassed = 0
		local Char = v.Parent
		local PreviousPosition = Char.HumanoidRootPart.Position
		repeat
			game:GetService("RunService").Heartbeat:Wait()
			local Filter = {workspace.MouseIgnore,workspace.Living,Char}
			local Partray = Raycast(PreviousPosition,CFrame.lookAt(PreviousPosition,Char.HumanoidRootPart.Position).LookVector*(PreviousPosition - Char.HumanoidRootPart.Position).magnitude,Enum.RaycastFilterType.Exclude,Filter)
			PreviousPosition = Char.HumanoidRootPart.Position
			if Partray ~= nil then
				local x = Partray.Instance
				local Part2 = Partray
				Char.HumanoidRootPart.CFrame = CFrame.new(Partray.Position)*CFrame.Angles(math.rad(Char.HumanoidRootPart.Orientation.X),math.rad(Char.HumanoidRootPart.Orientation.Y),math.rad(Char.HumanoidRootPart.Orientation.Z))
				local Broke = false
				local Part = nil
				if x:IsA("BasePart") and x.CanCollide == true and x.Name ~= "Torso" and x ~= Part and not x:IsDescendantOf(v.Parent) and not x.Parent:FindFirstChild("Humanoid") or x:IsA("MeshPart") and x.CanCollide == true and x.Name ~= "Torso" and x ~= Part and not x:IsDescendantOf(v.Parent) and not x.Parent:FindFirstChild("Humanoid") or x:IsA("UnionOperation") and x.CanCollide == true and x.Name ~= "Torso" and x ~= Part and not x:IsDescendantOf(v.Parent) and not x.Parent:FindFirstChild("Humanoid") then
					local Anim2 = Instance.new("Animation")
					Anim2.AnimationId = "rbxassetid://"..AnimationID
					local Anim2 = v.Parent.Humanoid:LoadAnimation(Anim2)
					Anim2:Play()
					Anim2:AdjustSpeed(AnimSpeed / workspace.SpeedUp.Value)
					Anim2.TimePosition = TimePosition
					if Anim ~= nil then
						Anim:Stop()
					end
					Tween:Cancel()
					Char.HumanoidRootPart.CFrame = CFrame.new(Partray.Position)*CFrame.Angles(math.rad(Char.HumanoidRootPart.Orientation.X),math.rad(Char.HumanoidRootPart.Orientation.Y),math.rad(Char.HumanoidRootPart.Orientation.Z))
					PlaySound(4326342774, v.Parent.Torso, 5, 0.5 * 1.5)
					Debris(x,Part2.Position)
					Broke = true
					if not v.Parent:FindFirstChild("Armor") then
						for i,x in pairs(v.Parent:GetChildren()) do
							if x.Name == "Stun" then
								x:Destroy()
							end
						end
						local Stun = Instance.new("BoolValue")
						Stun.Name = "Stun"
						Stun.Parent = v.Parent
						local Connection2 = nil
						Connection2 = Stun.AncestryChanged:Connect(function()
							if not Stun:IsDescendantOf(workspace) then
								Connection2:Disconnect()
								Anim2:Stop()
							end
						end)
						local StunDuration = WallStun
						if DurationBasedOnTimePassed == true then
							StunDuration = (Duration + WallStun) - (os.clock() - Start)
						end
						RemoveItem(Stun,StunDuration)
						if IFrames == true then
							Inv:Destroy()
							local Invincibility2 = Instance.new("BoolValue")
							Invincibility2.Name = "Invincibility"
							Invincibility2.Parent = v.Parent
							RemoveItem(Invincibility2,StunDuration + 0.5)
						end
					end
					v.Parent.HumanoidRootPart.Anchored = false
					if UpwardsVelocity ~= false then
						v.Parent.HumanoidRootPart.Velocity = Vector3.new(0,50,0)
					end
					if Broke == true then
						break
					end
				end
			end
		until v.Parent.Humanoid.Health <= 0 or Stunned2 == true or os.clock() - Start >= workspace.SpeedUp.Value * Duration
		Connection:Disconnect()
		Tween:Cancel()
		if Anim ~= nil then
			Anim:Stop()
		end
		v.Parent.Humanoid.AutoRotate = true
		v.Parent.HumanoidRootPart.Anchored = false
	end)
end
