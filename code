local function AccurateWait(Timer, Time, Returnable)
	local TimeRequired = workspace.SpeedUp.Value * Time
	local elapsed = os.clock() - Timer

	if Returnable then
		return math.max(0, TimeRequired - elapsed)
	else
		repeat
			task.wait()
		until os.clock() - Timer >= TimeRequired
	end
end
