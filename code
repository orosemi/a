local function MagnitudeDetect(Part,Magn,Character)
	local HitPeopleTable = {} 
	for i,v in pairs(workspace.Living:GetChildren()) do
		if not Character.Allies:FindFirstChild(v.Name) then
			for i,hit in pairs(v:GetChildren()) do
				if hit:IsA("BasePart") or hit:IsA("Part") then
					local Magnitude = (hit.Position - Part.Position).magnitude
					if Magnitude <= Magn then
						table.insert(HitPeopleTable,hit)
					end
				end
			end
		end
	end
	return HitPeopleTable
end
